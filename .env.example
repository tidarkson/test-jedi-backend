# Test-Jedi Backend - Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ========================================
# Database Configuration
# ========================================
# PostgreSQL connection string for Prisma
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
DATABASE_URL="postgresql://postgres:password@localhost:5432/test_jedi_dev"

# Example for containerized PostgreSQL:
# DATABASE_URL="postgresql://postgres:your_password@postgres:5432/test_jedi_dev"

# ========================================
# Authentication & JWT
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=your-session-secret-change-this-in-production

# ========================================
# Redis Configuration
# ========================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
# Or for Redis with authentication:
# REDIS_URL=redis://:password@localhost:6379

# ========================================
# CORS & Frontend
# ========================================
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ========================================
# Logging
# ========================================
LOG_LEVEL=info
# Options: error, warn, info, http, debug, verbose, silly

# ========================================
# Error Tracking (Sentry)
# ========================================
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456
SENTRY_ENVIRONMENT=development
# Options: development, staging, production

# ========================================
# Email Configuration
# ========================================
EMAIL_PROVIDER=TEST
# Options: TEST (console output), GMAIL, SENDGRID, SMTP
EMAIL_FROM=noreply@test-jedi.com

# Gmail Configuration (if EMAIL_PROVIDER=GMAIL)
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password

# Sendgrid Configuration (if EMAIL_PROVIDER=SENDGRID)
SENDGRID_API_KEY=SG.your-api-key-here

# SMTP Configuration (if EMAIL_PROVIDER=SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# 15 minutes, 100 requests max

# ========================================
# Third-Party Integrations
# ========================================

# Jira Integration
JIRA_ENABLED=false
JIRA_HOST=https://your-jira-instance.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USERNAME=your-email@example.com

# GitHub Integration
GITHUB_ENABLED=false
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=your-github-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitLab Integration
GITLAB_ENABLED=false
GITLAB_HOST=https://gitlab.com
GITLAB_ACCESS_TOKEN=your-gitlab-token

# Slack Integration
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_APP_SIGNING_SECRET=your-signing-secret

# Azure DevOps Integration
AZURE_ENABLED=false
AZURE_ORG=your-org-name
AZURE_PAT=your-personal-access-token
AZURE_PROJECT=your-project-name

# ========================================
# File Storage (for uploads)
# ========================================
STORAGE_TYPE=local
# Options: local, s3, gcs, azure

# S3 Configuration (if STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=test-jedi-uploads

# Google Cloud Storage Configuration (if STORAGE_TYPE=gcs)
GCS_PROJECT_ID=your-project-id
GCS_BUCKET=test-jedi-uploads
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Azure Blob Storage Configuration (if STORAGE_TYPE=azure)
AZURE_STORAGE_ACCOUNT=your-account-name
AZURE_STORAGE_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=test-jedi-uploads

# ========================================
# Feature Flags
# ========================================
FEATURE_ANALYTICS_ENABLED=true
FEATURE_CUSTOM_FIELDS_ENABLED=true
FEATURE_INTEGRATIONS_ENABLED=true
FEATURE_TEST_AUTOMATION_ENABLED=true
FEATURE_REAL_TIME_UPDATES_ENABLED=true

# ========================================
# Job Queue Configuration (BullMQ)
# ========================================
BULL_QUEUE_ENABLED=true
BULL_DEFAULT_REPEAT_DELAY=1000

# ========================================
# Analytics & Telemetry
# ========================================
TELEMETRY_ENABLED=false
ANALYTICS_API_KEY=your-analytics-key

# ========================================
# Development Tools
# ========================================
DEBUG=test-jedi:*
# Set to enable debug logging for specific modules

# ========================================
# Seed Data Configuration (Development Only)
# ========================================
SEED_DATABASE=false
# Set to true to automatically seed data on startup (development only)
