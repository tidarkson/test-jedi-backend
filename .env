NODE_ENV=development
PORT=3000
HOST=localhost

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/test_jedi_dev"

JWT_SECRET=dev-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=dev-session-secret-change-in-production

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

LOG_LEVEL=info

SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

EMAIL_PROVIDER=TEST
EMAIL_FROM=noreply@test-jedi.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

STORAGE_TYPE=local

FEATURE_ANALYTICS_ENABLED=true
FEATURE_CUSTOM_FIELDS_ENABLED=true
FEATURE_INTEGRATIONS_ENABLED=true
FEATURE_TEST_AUTOMATION_ENABLED=true
FEATURE_REAL_TIME_UPDATES_ENABLED=true

TELEMETRY_ENABLED=false
DEBUG=test-jedi:*
SEED_DATABASE=false
